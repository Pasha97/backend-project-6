{
  "name": "@hexlet/code",
  "version": "1.0.0",
  "description": "Hexlet backend project 6",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "build": "webpack && knex migrate:latest",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --verbose --runInBand --forceExit",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/__tests__/helpers/"
    ],
    "setupFiles": [
      "dotenv/config"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/formbody": "^8.0.0",
    "@fastify/passport": "^2.4.0",
    "@fastify/session": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "i18next": "^23.0.0",
    "knex": "^3.1.0",
    "objection": "^3.1.4",
    "passport-local": "^1.0.0",
    "pg": "^8.13.0",
    "pug": "^3.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "bootstrap": "^5.3.0",
    "css-loader": "^6.0.0",
    "jest": "^29.0.0",
    "mini-css-extract-plugin": "^2.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  }
}
