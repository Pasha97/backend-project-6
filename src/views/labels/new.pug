extends ../layout.pug

block title
  | #{t('newLabelTitle')}

block content
  .row.justify-content-center
    .col-12.col-md-8
      form(action="/labels" method="post")
        .form-floating.mb-3
          input.form-control(
            class=errors && errors.name ? 'is-invalid' : ''
            id="data_name"
            name="name"
            value=data && data.name || ''
            placeholder=t('labelName')
            type="text"
          )
          if errors && errors.name
            .invalid-feedback.form-control-feedback #{errors.name[0]}
          label(for="data_name") #{t('labelName')}
        input.btn.btn-primary(type="submit" value=t('create'))
