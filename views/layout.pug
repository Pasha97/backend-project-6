doctype html
html(lang="ru")
  head
    meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
    title Hexlet Task Manager
    script(src="/assets/main.js")
    link(href="/assets/main.css" rel="stylesheet")
  body.d-flex.flex-column.min-vh-100.bg-light
    nav.navbar.navbar-expand-lg.navbar-light.bg-white
      .container
        a.navbar-brand(href="/") #{t('appName')}
        button.navbar-toggler(data-bs-toggle="collapse" data-bs-target="#navbarToggleExternalContent")
          span.navbar-toggler-icon
        #navbarToggleExternalContent.collapse.navbar-collapse
          ul.navbar-nav.justify-content-end.w-100
            li.nav-item
              a.nav-link(href="/users") #{t('users')}
            li.nav-item
              a.nav-link(href="/statuses") #{t('statuses')}
            li.nav-item.me-auto
              a.nav-link(href="/tasks") #{t('tasks')}
            if currentUser
              li.nav-item
                a.nav-link(href=`/users/${currentUser.id}/edit`) #{currentUser.fullName}
              li.nav-item
                form(action="/session" method="post")
                  input(type="hidden" name="_method" value="DELETE")
                  button.nav-link.btn.btn-link(type="submit") #{t('signOut')}
            else
              li.nav-item
                a.nav-link(href="/session/new") #{t('signIn')}
              li.nav-item
                a.nav-link(href="/users/new") #{t('signUp')}
    .container.wrapper.flex-grow-1
      h1.display-4.fw-bold.mt-4
        block title
      if flash && flash.message
        .alert(class=`alert-${flash.type}`) #{flash.message}
      block content
    footer.bg-dark.text-light
      .container.py-3
        p.lead.mb-0 #{t('footer')}
