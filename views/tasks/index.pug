extends ../layout.pug

block title
  | #{t('tasksTitle')}

block content
  if currentUser
    a.btn.btn-primary.mt-4.mb-3(href="/tasks/new") #{t('newTaskLink')}
  form(action="/tasks" method="get")
    .row.g-3.mb-3
      .col-12.col-md-3
        select.form-select(id="data_status" name="statusId")
          option(value="") #{t('taskStatus')}
          each status in statuses
            option(value=status.id selected=(filter && String(filter.statusId) === String(status.id))) #{status.name}
      .col-12.col-md-3
        select.form-select(id="data_executor" name="executorId")
          option(value="") #{t('taskExecutor')}
          each user in users
            option(value=user.id selected=(filter && String(filter.executorId) === String(user.id))) #{user.fullName}
      .col-12.col-md-3
        select.form-select(id="data_label" name="labelId")
          option(value="") #{t('taskLabel')}
          each label in labels
            option(value=label.id selected=(filter && String(filter.labelId) === String(label.id))) #{label.name}
      .col-12.col-md-3
        .form-check.mt-2
          input.form-check-input(
            type="checkbox"
            id="filter_isCreatorUser"
            name="isCreatorUser"
            value="1"
            checked=(filter && filter.isCreatorUser === '1')
          )
          label.form-check-label(for="filter_isCreatorUser") #{t('filterIsCreatorUser')}
    button.btn.btn-secondary(type="submit") #{t('filterShow')}
  .table-responsive
    table.table.table-borderless.table-striped.mt-3.bg-white
      thead
        tr
          th #{t('id')}
          th #{t('taskName')}
          th #{t('taskStatus')}
          th #{t('taskCreator')}
          th #{t('taskExecutor')}
          th #{t('createdAt')}
          th #{t('actions')}
      tbody
        each task in tasks
          tr
            td #{task.id}
            td
              a(href=`/tasks/${task.id}`) #{task.name}
            td #{task.status ? task.status.name : ''}
            td #{task.creator ? task.creator.fullName : ''}
            td #{task.executor ? task.executor.fullName : ''}
            td #{new Date(task.created_at).toLocaleDateString('ru-RU')}
            td
              if currentUser
                a.me-2(href=`/tasks/${task.id}/edit`) #{t('editLink')}
                if String(currentUser.id) === String(task.creatorId)
                  form.d-inline(action=`/tasks/${task.id}` method="post")
                    input(type="hidden" name="_method" value="DELETE")
                    button.btn.btn-link.p-0.text-danger(type="submit") #{t('deleteButton')}
