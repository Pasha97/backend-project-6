extends ../layout.pug

block title
  | #{task.name}

block content
  p
    strong #{t('taskStatus')}:
    |  #{task.status ? task.status.name : ''}
  p
    strong #{t('taskCreator')}:
    |  #{task.creator ? task.creator.fullName : ''}
  p
    strong #{t('taskExecutor')}:
    |  #{task.executor ? task.executor.fullName : ''}
  if task.labels && task.labels.length > 0
    p
      strong #{t('taskLabels')}:
      |  #{task.labels.map(l => l.name).join(', ')}
  if task.description
    p
      strong #{t('taskDescription')}:
      |  #{task.description}
  p
    strong #{t('createdAt')}:
    |  #{new Date(task.created_at).toLocaleDateString('ru-RU')}
